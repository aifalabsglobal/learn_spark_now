# Clerk — get keys from https://dashboard.clerk.com → API Keys
# This is a Vite app: use VITE_CLERK_PUBLISHABLE_KEY (not NEXT_PUBLIC_*).
# Only VITE_* variables are exposed to the client bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: for server-side only (API routes, webhooks). Not used by the Vite client.
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
